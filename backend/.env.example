# Copy to .env and fill in. Never commit .env.

# App
NODE_ENV=development
PORT=8080
# Comma-separated allowed browser origins for CORS (your frontend URL).
CORS_ORIGIN=http://localhost:5173

# Secrets — generate strong random values (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-string

# The app connects as the restricted, RLS-enforced role `helm_app`.
DATABASE_URL=postgres://helm_app:CHANGE_ME_APP_PASSWORD@localhost:5432/helm

# Migrations run as an admin/owner role (creates tables, roles, RLS policies).
DATABASE_ADMIN_URL=postgres://postgres:CHANGE_ME_ADMIN_PASSWORD@localhost:5432/helm

# Password assigned to the helm_app role by the migration runner.
APP_DB_PASSWORD=CHANGE_ME_APP_PASSWORD
